        <xi:include href="../../attributes/provenance/organization.xml"
            xmlns:xi="http://www.w3.org/2001/XInclude"/>
        <xi:include href="../../attributes/provenance/person.xml"
            xmlns:xi="http://www.w3.org/2001/XInclude"/>
        <xi:include href="../../attributes/provenance/ref.xml"
            xmlns:xi="http://www.w3.org/2001/XInclude"/>
        <xi:include href="../../attributes/provenance/tool.xml"
            xmlns:xi="http://www.w3.org/2001/XInclude"/>
        <xi:include href="../../attributes/provenance/timestamp.xml"
            xmlns:xi="http://www.w3.org/2001/XInclude"/>
        <xi:include href="../../attributes/provenance/usageUnit.xml"
            xmlns:xi="http://www.w3.org/2001/XInclude"/>
    </section>
    
    <section>
        <title>Full Example</title>
        <programlisting>
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;xliff srcLang="en" trgLang="es" version="2.3"
    xmlns:pvn="urn:oasis:names:tc:xliff:pvn:2.3"
    xmlns:its="http://www.w3.org/2005/11/its"
    xmlns="urn:oasis:names:tc:xliff:document:2.3"&gt;
    &lt;file id="f1"&gt;
        &lt;unit id="1" its:locQualityRatingScore="0.968"&gt;
            &lt;pvn:provenance&gt;
                &lt;pvn:change agent="Google Translate" appliesTo="target"
                    timestamp="2026-05-05T21:06:00.000Z"&gt;
                    &lt;pvn:usage usageUnit="characters"&gt;66&lt;/pvn:usage&gt;
                    &lt;pvn:value&gt;O seu certificado anual de impostos está 
                      dispoñible para descarga.&lt;/pvn:value&gt;
                &lt;/pvn:change&gt;
                &lt;pvn:change appliesTo="its:locQualityRatingScore"
                    agent="TAUS MTQE" timestamp="2026-05-05T21:07:00.000Z"&gt;
                    &lt;pvn:usage usageUnit="characters"&gt;66&lt;/pvn:usage&gt;
                    &lt;pvn:value&gt;0.968&lt;/pvn:value&gt;
                &lt;/pvn:change&gt;
                &lt;pvn:change agent="gpt-5.5" appliesTo="target"
                    timestamp="2026-05-05T21:08:00.000Z"
                    intent="This version sounds slightly smoother and more 
                    idiomatic: 'para descargar' is often preferred over 
                    'para descarga' in everyday usage."&gt;
                    &lt;pvn:usage usageUnit="token"&gt;45&lt;/pvn:usage&gt;
                    &lt;pvn:value&gt;O seu certificado anual de impostos xa está 
                        dispoñible para descargar.&lt;/pvn:value&gt;
                &lt;/pvn:change&gt;
            &lt;/pvn:provenance&gt;
            &lt;segment&gt;
                &lt;source&gt;Your annual tax certificate is now available for
                    download.&lt;/source&gt;
                &lt;target&gt;O seu certificado anual de impostos xa está 
                    dispoñible para descargar.&lt;/target&gt;
            &lt;/segment&gt;
        &lt;/unit&gt;
    &lt;/file&gt;
&lt;/xliff&gt;    
</programlisting>
    </section>

